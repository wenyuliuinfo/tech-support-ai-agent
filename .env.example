# === DeepSeek Chat === 
CHAT_API_KEY="sk-..."
CHAT_BASE_URL="https://api.deepseek.com/v1"
CHAT_MODEL="deepseek-v4-pro"

# === Embedding (ZHIPU) ===
EMBEDDING_API_KEY="your-zhipu-key"
EMBEDDING_BASE_URL="https://open.bigmodel.cn/api/paas/v4/"
EMBEDDING_MODEL="embedding-3"
EMBEDDING_DIMENSION=1024

# === Pinecone ===
PINECONE_API_KEY="your_key_here"
PINECONE_HOST_URL="http://localhost:5080"
PINECONE_INDEX_NAME="knowledge-base"

# === PostgreSQL ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME="your_db_name"
DB_USER="your_user_name"
DB_PASSWORD="your_password"
DATABASE_URL="postgresql+asyncpg://your_user_name:your_password@localhost:5432/your_db_name"

# Frontend (Next.js)
NEXT_PUBLIC_AUTH0_DOMAIN="your-tenant.auth0.com"
NEXT_PUBLIC_AUTH0_CLIENT_ID="your_client_id"
NEXT_PUBLIC_AUTH0_AUDIENCE="https://your-api.example.com"
NEXT_PUBLIC_API_URL="http://localhost:8000"

# Backend (FastAPI)
API_URL="http://localhost:8000"

# Auth0 SDK (Next.js proxy)
# Generate with: openssl rand -hex 32
AUTH0_SECRET="your_secret_here"
AUTH0_DOMAIN="your_domain_here"
AUTH0_CLIENT_ID="your_client_id"
AUTH0_CLIENT_SECRET="your_client_secret"

# === Auth (Auth0 Passwordless — Email Magic Link) ===
IDP_DOMAIN="your-tenant.auth0.com"
IDP_CLIENT_ID="your_client_id"
IDP_CLIENT_SECRET="your_client_secret"
IDP_AUDIENCE="https://your-api.example.com"
 
# === CORS ===
CORS_ORIGIN="http://localhost:3000"

# === App ===
APP_ENV="local"
LOG_LEVEL="info"
RATE_LIMIT_PER_ACCOUNT_PER_MIN=1000
